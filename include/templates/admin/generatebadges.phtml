<?php if (empty($this->participants)) : ?>
  <p>No participants found.</p>
<?php else : ?>
  <div class="badge-grid">
    <?php foreach ($this->participants as $participant) : ?>
      <div class="print-wrapper">
        <div class="id-badge">
          <?php
          $frame_class = (method_exists($participant, 'isArrangoer') && $participant->isArrangoer()) ? 'red' : 'blue';
          $photo = isset($this->photos[$participant->id]) ? $this->photos[$participant->id] : '';
          $show_photo = false;
          if ($photo) {
            $file_path = defined('PUBLIC_PATH') ? PUBLIC_PATH . ltrim($photo, '/') : __DIR__ . '/../../../public' . $photo;
            if (file_exists($file_path)) {
              $show_photo = true;
            }
          }
          ?>
          <div class="badge-header flex center <?= $frame_class ?>">
            <div class="flex col center" style="width: 100%;">
              <span class="header-text"><?php $lang = ($participant->main_lang ?? 'da') === 'en' ? 'en' : 'da';
                                        echo $participant->isArrangoer() ? ($lang === 'en' ? 'ORGANIZER' : 'ARRANGØR') : ($lang === 'en' ? 'PARTICIPANT' : 'DELTAGER'); ?></span>
              <span class="header-text"><?= htmlentities($participant->id); ?></span>
            </div>
            <?php if ($show_photo): ?>
              <img class="photo" src="<?= $photo; ?>" alt="<?= htmlentities($participant->getName()); ?>" />
            <?php else: ?>
              <img class="logo" src="/img/logo2026.png" alt="logo" />
            <?php endif; ?>
          </div>

          <div class="details">
            <div class="flex col between" style="width: 100%">
              <?php if (!empty($participant->pronouns) || method_exists($participant, 'getPronoun')): ?>
                <span class="name"><?= htmlentities($participant->getName()); ?></span>
                <span class="pronouns">
                  <?php if (method_exists($participant, 'getPronoun')) {
                    echo htmlentities($participant->getPronoun());
                  } else {
                    echo htmlentities($participant->pronouns);
                  }
                  ?></span>
              <?php endif; ?>
              <?php $lang = ($participant->main_lang ?? 'da') === 'en' ? 'en' : 'da';
              $wa_data = $this->work_areas[$participant->work_area] ?? null; ?>
              <span class="role"><?= htmlentities($wa_data ? $wa_data[$lang] : ''); ?></span>
