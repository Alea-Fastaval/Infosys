<script>
  document.addEventListener('DOMContentLoaded', function() {
    const generateBtn = document.getElementById('generate-pdf-btn');
    const generate10Btn = document.getElementById('generate-pdf-10-btn');
    const statusSpan = document.getElementById('pdf-status');

    function generatePDF(limit) {
      generateBtn.disabled = true;
      generate10Btn.disabled = true;
      statusSpan.style.display = 'inline';
      statusSpan.textContent = limit ? 'Genererer PDF med ' + limit + ' skilte...' : 'Genererer PDF med alle skilte...';
      statusSpan.style.color = '#007bff';

      const url = '/admin/generate-badges-pdf' + (limit ? '?limit=' + limit : '');

      fetch(url, {
          method: 'GET'
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Failed to generate PDF');
          }
          const contentDisposition = response.headers.get('content-disposition');
          let filename = 'deltager-navneskilte.pdf';
          if (contentDisposition) {
            const filenameMatch = contentDisposition.match(/filename="?([^"]+)"?/);
            if (filenameMatch) {
              filename = filenameMatch[1];
            }
          }
          return response.blob().then(blob => ({
            blob,
            filename
          }));
        })
        .then(({
          blob,
          filename
        }) => {
          const objectUrl = window.URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.href = objectUrl;
          link.download = filename;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
          window.URL.revokeObjectURL(objectUrl);

          statusSpan.textContent = 'PDF genereret og hentet!';
          statusSpan.style.color = '#28a745';

          setTimeout(() => {
            statusSpan.style.display = 'none';
            generateBtn.disabled = false;
            generate10Btn.disabled = false;
          }, 3000);
        })
        .catch(error => {
          console.error('Error:', error);
          statusSpan.textContent = 'Fejl ved generering af PDF: ' + error.message;
          statusSpan.style.color = '#dc3545';
          generateBtn.disabled = false;
          generate10Btn.disabled = false;
        });
    }

    generateBtn.addEventListener('click', function() {
      generatePDF(0);
    });
    generate10Btn.addEventListener('click', function() {
      generatePDF(10);
    });
  });
</script>